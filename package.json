{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "build": "npm run typecheck && npm run -ws --if-present build",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run -ws --if-present typecheck"
  },
  "private": true,
  "workspaces": [
    "artifacts/api-server",
    "artifacts/event-flow",
    "artifacts/mockup-sandbox",
    "lib/*",
    "lib/integrations/*",
    "scripts"
  ],
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
